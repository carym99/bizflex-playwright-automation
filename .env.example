# Copy to .env.local — never commit real credentials or tenant IDs.

PLAYWRIGHT_BASE_URL=https://bizflex-app.netlify.app
BASE_URL=https://bizflex-app.netlify.app

TEST_EMAIL=your_test_email_here
TEST_PASSWORD=your_test_password_here

# UI login / account-selection (defaults to TEST_* when unset)
# UI_USER_EMAIL=your_ui_login_email
# UI_USER_PASSWORD=your_ui_login_password

VALID_USER_EMAIL=your_valid_user_email_here
# VALID_USER_PASSWORD=your_valid_user_password

API_URL=https://bizflex.onrender.com
# AUTH_API_LOGIN_PATH=/v1/auth/login

# Default account for npm run auth + loginAndSelectAccount
# E2E_SELECT_ACCOUNT_TYPE=freelance
# E2E_SELECT_ACCOUNT_NAME=
# E2E_SELECT_ACCOUNT_ID=
# E2E_SELECT_ACCOUNT_CONTEXT_ID=

# Freelance (API type: individual | contexts: FREELANCE)
# E2E_FREELANCE_ACCOUNT_NAME=
# E2E_FREELANCE_ACCOUNT_ID=
# E2E_FREELANCE_ACCOUNT_CONTEXT_ID=
# E2E_FREELANCE_WALLET_ID=
# E2E_FREELANCE_BUSINESS_ID=

# Primary business
# E2E_BUSINESS_ACCOUNT_NAME=
# E2E_BUSINESS_ACCOUNT_ID=
# E2E_BUSINESS_ACCOUNT_CONTEXT_ID=
# E2E_BUSINESS_ID=
# E2E_BUSINESS_WALLET_ID=

# Second business (optional — business-to-business switch tests)
# E2E_BUSINESS_ACCOUNT_NAME_2=
# E2E_BUSINESS_ACCOUNT_ID_2=
# E2E_BUSINESS_ACCOUNT_CONTEXT_ID_2=
# E2E_BUSINESS_ID_2=
# E2E_BUSINESS_WALLET_ID_2=

# Legacy aliases (optional)
# E2E_DEFAULT_ACCOUNT_ID=
# E2E_DEFAULT_ACCOUNT_CONTEXT_ID=
# E2E_PREFER_LAST_USED_ACCOUNT=1

# Account context API (optional — auto-tries common paths if unset)
# ACCOUNT_CONTEXTS_PATH=/v1/users/contexts
# AUTH_SESSION_PATH=/v1/users/profile

# Payment settings API happy path (required for PATCH success test)
# PAYMENT_SETTINGS_ACCOUNT_ID=
# PAYMENT_SETTINGS_SETTING_ID=

# Transfer API happy path (required — debits balance; set SKIP_LIVE_TRANSFER=1 to disable)
TRANSFER_ACCOUNT_ID=your_wallet_or_account_id
TRANSFER_TRANSACTION_PIN=your_pin
# SKIP_LIVE_TRANSFER=1
TRANSFER_BANK_CODE=232
TRANSFER_BENEFICIARY_ACCOUNT_NAME=BizFlex TestUser
TRANSFER_BENEFICIARY_ACCOUNT_NUMBER=0000000000
TRANSFER_BENEFICIARY_BANK_NAME=Example Bank
TRANSFER_LARGE_AMOUNT=100000000
